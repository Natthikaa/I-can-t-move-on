<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>💙 ใครเกิดก่อนแก่</title>

<style>
body{
  margin:0;
  font-family:sans-serif;
  background:linear-gradient(135deg,#b3e5fc,#e1f5fe,#d0f0ff);
  overflow:hidden;
}

h1{
  text-align:center;
  color:#0277bd;
}

#cards{
  display:flex;
  flex-wrap:wrap;
  justify-content:center;
}

.card{
  background:rgba(255,255,255,0.75);
  backdrop-filter:blur(10px);
  width:200px;
  margin:10px;
  padding:15px;
  border-radius:20px;
  text-align:center;
  box-shadow:0 6px 20px rgba(0,0,0,0.1);
  cursor:pointer;
}

.count{
  color:#0288d1;
  font-weight:bold;
  margin-top:8px;
}

/* profile page */
#profile{
  display:none;
  text-align:center;
}

input{
  padding:10px;
  border:none;
  border-radius:10px;
  width:200px;
}

button{
  padding:10px 14px;
  border:none;
  border-radius:10px;
  background:#4fc3f7;
  color:white;
  margin:5px;
}

/* floating msg */
.msg{
  position:fixed;
  left:50%;
  transform:translateX(-50%);
  bottom:0;
  background:white;
  padding:10px 15px;
  border-radius:20px;
  animation:rise 4s forwards;
  box-shadow:0 5px 15px rgba(0,0,0,0.2);
}

@keyframes rise{
  0%{bottom:0; opacity:1;}
  100%{bottom:70vh; opacity:0;}
}

/* sticker */
.sticker{
  position:fixed;
  bottom:-50px;
  font-size:22px;
  animation:floatUp linear forwards;
  opacity:0.7;
  pointer-events:none;
}

@keyframes floatUp{
  to{transform:translateY(-120vh);}
}

/* birthday */
.bday{
  position:fixed;
  top:0;
  left:0;
  width:100%;
  height:100%;
  background:linear-gradient(135deg,#4fc3f7,#81d4fa);
  display:flex;
  justify-content:center;
  align-items:center;
  font-size:35px;
  color:white;
  z-index:999;
}
</style>
</head>

<body>

<h1>COUNTDOWN BD</h1>

<div id="cards"></div>

<div id="profile">
  <h2 id="name"></h2>

  <div id="count"></div>

  <h3>💬 ส่งข้อความหาเพื่อนที่ไม่เต็ม</h3>

  <input id="msgInput" placeholder="พิมพ์ข้อความ...">
  <br>
  <button onclick="sendMsg()">ส่ง</button>
  <button onclick="back()">⬅ กลับ</button>
  <button onclick="resetMsg()">🔄 รีเซ็ตข้อความ</button>
</div>

<script>
const friends=[
{name:"Porjai",date:"2026-05-11T00:00:00"},
{name:"Woonsen",date:"2026-05-17T00:00:00"},
{name:"Earn",date:"2026-06-08T00:00:00"},
{name:"Gaemmy",date:"2026-06-12T00:00:00"},
{name:"Namwine",date:"2026-10-18T00:00:00"},
{name:"Army",date:"2027-03-08T00:00:00"},
];

let current=null;

/* render cards */
function render(){
  let box=document.getElementById("cards");
  box.innerHTML="";
  friends.forEach((f,i)=>{
    box.innerHTML+=`
    <div class="card" onclick="openP(${i})">
      <h3>${f.name}</h3>
      <div class="count" id="c${i}"></div>
    </div>`;
  });
}

/* countdown */
function update(){
  let now=new Date();

  friends.forEach((f,i)=>{
    let t=new Date(f.date);
    if(t<now)t.setFullYear(now.getFullYear()+1);

    let d=t-now;
    let day=Math.floor(d/86400000);
    let h=Math.floor(d/3600000)%24;
    let m=Math.floor(d/60000)%60;
    let s=Math.floor(d/1000)%60;

    document.getElementById("c"+i).innerText=
    `${day}d ${h}h ${m}m ${s}s`;

    if(day===0&&h===0&&m===0&&s===0){
      birthday(f.name);
    }
  });
}

/* open profile */
function openP(i){
  current=i;
  document.getElementById("cards").style.display="none";
  document.getElementById("profile").style.display="block";
  document.getElementById("name").innerText=friends[i].name;
}

/* back */
function back(){
  document.getElementById("cards").style.display="flex";
  document.getElementById("profile").style.display="none";
}

/* send msg (per person) */
function sendMsg(){
  let val=document.getElementById("msgInput").value;
  if(!val) return;

  let m=document.createElement("div");
  m.className="msg";
  m.innerText=friends[current].name+": "+val;
  document.body.appendChild(m);

  setTimeout(()=>m.remove(),4000);
  document.getElementById("msgInput").value="";
}

/* reset floating msgs */
function resetMsg(){
  document.querySelectorAll(".msg").forEach(e=>e.remove());
}

/* stickers */
const emojis=["🎂","🐝","🐰","🐜","😈","👅"];
setInterval(()=>{
  let s=document.createElement("div");
  s.className="sticker";
  s.innerText=emojis[Math.floor(Math.random()*emojis.length)];
  s.style.left=Math.random()*100+"vw";
  s.style.animationDuration=(5+Math.random()*5)+"s";
  document.body.appendChild(s);
  setTimeout(()=>s.remove(),10000);
},700);

/* birthday */
function birthday(name){
  let b=document.createElement("div");
  b.className="bday";
  b.innerText="🎉 HAPPY BIRTHDAY "+name+" 🎉";
  document.body.appendChild(b);
  setTimeout(()=>b.remove(),5000);
}

render();
setInterval(update,1000);
</script>

</body>
</html>
